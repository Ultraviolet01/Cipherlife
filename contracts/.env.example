# Frontend (copy after deploy)
VITE_CONTRACT_ADDRESS=deployed_address_here
VITE_OPENAI_API_KEY=your_openai_api_key
VITE_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# ML API (copy after Railway deploy)
VITE_ML_API_URL=https://your-app.railway.app
