{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "builds": [
    { "src": "backend/index.js", "use": "@vercel/node" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "backend/index.js" },
    { "source": "/analyze/(.*)", "destination": "backend/index.js" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
